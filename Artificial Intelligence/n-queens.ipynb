import random
import time
import csv

def conflicts(board,type):
    N = len(board) if type != 'array' else len(board)

    if type == 'tuple':
        for i in range(N):
            for j in range(i + 1,N):
                r1,c1 = board[i]
                r2,c2 = board[j]
                if r1 == r2 or c1 == c2 or abs(r1-r2) == abs(c1-c2):
                    return True
        return False
    if type == 'array':
        queens = []
        for i in range(N):
            for j in range(N):
                if board[i][j] == 1:
                    queens.append((i,j))
        for i in range(len(queens)):
            for j in range(i + 1,len(queens)):
                r1,c1 = queens[i]
                r2,c2 = queens[j]
                if r1 == r2 or c1 == c2 or abs(r1-r2) == abs(c1-c2):
                    return True
        return False
    if type == 'vector' or type == 'perm':
        queens = []
        for i in range(N):
            queens.append((i,board[i]))
        for i in range(len(queens)):
            for j in range(i + 1,len(queens)):
                r1,c1 = queens[i]
                r2,c2 = queens[j]
                if r1 == r2 or c1 == c2 or abs(r1-r2) == abs(c1-c2):
                    return True
        return False

def generate_board(N,type):
    position = list(range(N))
    random.shuffle(position)
    if type == 'tuple':
        return [(i,position[i]) for i in range(N)]
    if type == 'vector' or type == 'perm':
        return [position[i] for i in range(N)]
    if type == 'array':
        arr = [[0] * N for i in range(N)]
        pos = [(i,position[i]) for i in range(N)]
        for i,j in pos:
            arr[i][j] = 1
        return arr
    
def measure_time(N,type,x):
    start = time.time()
    correct = 0
    for i in range(x):
        board_test = generate_board(N,type)
        print(board_test)
        if conflicts(board_test,type) == False:
            correct += 1
    conflict_rate = (x - correct) / x
    end = time.time()    
    execution_time = end-start
    return execution_time,conflict_rate

def experiment():
    Ns = [4,8,16,32,64,128,258,512,1024]
    types = ['tuple','array','vector','perm']
    x = 100

    with open('results.csv','w',newline='') as f:
        writer = csv.writer(f)
        writer.writerow(['N','representation_type','execution_time','conflict_rate'])

        for N in Ns:
            for t in types:
                execution_time, conflict_rate = measure_time(N,t,x)
                writer.writerow([N,t,round(execution_time,5),round(conflict_rate,5)])

experiment()
